PORT=3000
SESSION_SECRET=change-this-local-secret

YOUTUBE_API_KEY=your-youtube-data-api-key

# Required for published Global YouTube Favs to persist forever.
# Vercel Redis usually gives REDIS_URL.
REDIS_URL=
# Older KV/Upstash setups may give REST env vars instead.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5-mini

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/tiktok/auth/callback
